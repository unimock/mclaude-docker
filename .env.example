# Copy to .env and adjust. Used by docker-compose.yml (long-running mode).

# Workspace root mounted into the container at the SAME path.
# One container can serve many projects below this directory.
MCLAUDE_WORKDIR=/home/youruser/MyGits

# Host UID/GID so files are written with the right ownership.
#   id -u  ->  CLAUDE_UID
#   id -g  ->  CLAUDE_GID
CLAUDE_UID=1000
CLAUDE_GID=1000

# Optional: timezone (defaults to UTC if unset)
# TZ=Europe/Berlin

# Optional: container hostname (defaults to "mclaude"). Shows up in the shell
# prompt and `hostname` inside the container.
# MCLAUDE_HOSTNAME=mclaude

# Optional: host port forwarded to the container's sshd (defaults to 2222).
# Log in with: ssh -p ${MCLAUDE_SSH_PORT} claude@<host>
# MCLAUDE_SSH_PORT=2222
