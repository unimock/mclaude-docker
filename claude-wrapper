#!/bin/sh -e

# workdir is provided via env (e.g. from docker compose), default for safety
: "${CLAUDE_WORKDIR:=/src}"

CLAUDE_UID="${CLAUDE_UID:-0}"
CLAUDE_GID="${CLAUDE_GID:-0}"

# Long-running mode: do the same UID/GID/docker-group setup as usual, but keep
# the container alive (PID 1 = tail) instead of exec'ing claude. You then attach
# with `docker compose exec -u claude mclaude bash` and run `claude` inside.
KEEPALIVE=0
if [ "$1" = "--keepalive" ]; then
    KEEPALIVE=1
    shift
fi

# Detect the Docker socket's GID and make sure a matching group exists, then
# add `claude` to it (Docker-in-Docker without root). Only meaningful when we
# drop to the unprivileged `claude` user; root is already in every group.
add_claude_to_docker_group() {
    DOCKER_GID=$(stat -c '%g' /var/run/docker.sock 2>/dev/null || true)
    [ -n "$DOCKER_GID" ] && [ "$DOCKER_GID" -ne 0 ] || return 0
    DOCKER_GROUP=$(getent group "$DOCKER_GID" | cut -d: -f1)
    if [ -z "$DOCKER_GROUP" ]; then
        groupadd -g "$DOCKER_GID" docker
        DOCKER_GROUP=docker
    fi
    usermod -aG "$DOCKER_GROUP" claude >/dev/null
}

# Long-running mode only: bring up an SSH daemon so you can `ssh claude@host`
# into the container instead of `docker exec`. Login is pre-shared-key only
# (see /etc/ssh/sshd_config.mclaude). Host keys and the authorized-keys file
# live in the mounted ~/.mclaude/.longrunning volume so they persist.
start_sshd() {
    LRDIR=/home/claude/.mclaude/.longrunning
    HOSTKEYS="$LRDIR/hostkeys"
    AUTHKEYS="$LRDIR/authorized-keys"

    mkdir -p "$HOSTKEYS"

    # Generate persistent host keys on first start (kept in the volume).
    [ -f "$HOSTKEYS/ssh_host_ed25519_key" ] || \
        ssh-keygen -q -t ed25519 -f "$HOSTKEYS/ssh_host_ed25519_key" -N ''
    [ -f "$HOSTKEYS/ssh_host_rsa_key" ] || \
        ssh-keygen -q -t rsa -b 4096 -f "$HOSTKEYS/ssh_host_rsa_key" -N ''
    chmod 700 "$HOSTKEYS"
    chmod 600 "$HOSTKEYS"/ssh_host_*_key

    # Privilege-separation directory required by sshd.
    mkdir -p /run/sshd

    if [ ! -s "$AUTHKEYS" ]; then
        echo "mclaude: no public keys in $AUTHKEYS — SSH login is refused until you add one." >&2
        echo "mclaude: append a key on the host, e.g. cat ~/.ssh/id_ed25519.pub >> ~/.mclaude/.longrunning/authorized-keys" >&2
    fi

    # Run in the foreground (-D) as a background job so its logs reach the
    # container's stderr (docker compose logs); PID 1 stays tail -f /dev/null.
    /usr/sbin/sshd -D -e -f /etc/ssh/sshd_config.mclaude &
    echo "mclaude: sshd started (pre-shared-key login as 'claude')." >&2
}

if [ "$CLAUDE_UID" -eq 0 ]; then
    # The host user is root (uid 0). We can't remap the `claude` user onto
    # uid 0 (that belongs to root), and dropping to the unprivileged `claude`
    # user would leave the root-owned project and config files unwritable.
    # So run Claude directly as root, where uid 0 == the host's uid 0 and file
    # ownership lines up. The mounted config lives under /home/claude, so point
    # HOME there.
    export HOME=/home/claude
    export TERM="${TERM:-xterm-256color}"
    export COLORTERM="${COLORTERM:-truecolor}"
    add_claude_to_docker_group
    if [ "$KEEPALIVE" -eq 1 ]; then
        start_sshd
        exec tail -f /dev/null
    fi
    cd "$CLAUDE_WORKDIR"
    exec /usr/local/bin/claude "$@"
fi

# --- non-root host user: remap `claude` to match, then drop privileges ---

# make sure files are written with correct user ownership
usermod -u "$CLAUDE_UID" claude >/dev/null

# make sure files are written with correct group ownership
if [ "$CLAUDE_GID" -ne 0 ]; then
    groupmod -g "$CLAUDE_GID" claude >/dev/null
fi

add_claude_to_docker_group

chown claude:claude /home/claude/.claude
# Re-chown npm globals so claude can auto-update after UID/GID change above
chown -R claude:claude /usr/local/lib/node_modules /usr/local/bin /usr/local/share/man 2>/dev/null || true

if [ "$KEEPALIVE" -eq 1 ]; then
    start_sshd
    exec tail -f /dev/null
fi

# NOTE: the `--` is required. Without it, su (util-linux) permutes the
# argument list and swallows anything starting with `-` (e.g. `-p`,
# `--debug`) as its own options instead of passing them to claude. The
# `--` ends su's option parsing so the trailing args reach the -c shell
# as positional parameters ($@). No $0 token is passed (su uses `-`),
# which claude ignores.
exec su claude - -c "export TERM='${TERM:-xterm-256color}'; export COLORTERM='${COLORTERM:-truecolor}'; cd '$CLAUDE_WORKDIR' && exec /usr/local/bin/claude \"\$@\"" -- "$@"
