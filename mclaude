#!/bin/sh

if [ "$PWD" = "$HOME" ]; then
  echo "Error: claude must not be run from the home directory." >&2
  exit 1
fi

if [ ! -f  $HOME/.mclaude/.claude.json ] ; then
  mkdir -p $HOME/.mclaude/
  touch    $HOME/.mclaude/.claude.json
fi

# Seed a default project config when the current directory has none yet.
if [ ! -f ./.claude/settings.json ] ; then
  mkdir -p ./.claude
  cat > ./.claude/settings.json <<'EOF'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-8",
  "autoMemory": false,
  "permissions": {
    "autoApprove": {
      "readFiles": true,
      "listFiles": true,
      "viewWebpage": true,
      "runReadOnlyCommands": true
    }
  },
  "git": {
    "suggestCommitMessages": true,
    "autoStage": false
  }
}
EOF
  echo "Created default Claude config at ./.claude/settings.json" >&2
fi
TZ_NAME=$(cat /etc/timezone 2>/dev/null || readlink -f /etc/localtime | sed 's@.*/zoneinfo/@@')

# Allocate a TTY only when running interactively. With piped input
# (e.g. `echo hi | mclaude -p`) stdin is not a TTY and `-t` would fail
# with "the input device is not a TTY".
TTY_FLAG=
if [ -t 0 ] && [ -t 1 ]; then
  TTY_FLAG=-t
fi

exec docker run -i $TTY_FLAG --rm -v $PWD:$PWD \
                         -e CLAUDE_WORKDIR="$PWD" \
                         -e CLAUDE_UID=$(id -u) \
                         -e CLAUDE_GID=$(id -g) \
                         -e TZ="$TZ_NAME" \
                         -e TERM="${TERM:-xterm-256color}" \
                         -e COLORTERM="${COLORTERM:-truecolor}" \
                         -v /etc/localtime:/etc/localtime:ro \
                         -v $HOME/.gitconfig:/home/claude/.gitconfig \
                         -v $HOME/.mclaude/.claude:/home/claude/.claude \
                         -v $HOME/.mclaude/.claude.json:/home/claude/.claude.json \
                         -v /var/run/docker.sock:/var/run/docker.sock \
                         mclaude /usr/local/bin/claude-wrapper "$@"

